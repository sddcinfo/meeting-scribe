# Phase 1 spike — throwaway image used to produce requirements.lock +
# wheelhouse.tar.zst. Not used in production. The production Dockerfile
# (see Dockerfile) installs strictly from those frozen artifacts.

ARG VLLM_BASE_TAG=v0.18.0
FROM vllm/vllm-openai:${VLLM_BASE_TAG}

ARG VLLM_OMNI_SHA=f55ea28005f889aa5f10d4ceb694573c564da127
ARG HF_MODEL_REVISION=0c0e3051f131929182e2c023b9537f8b1c68adfe
ARG HF_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_NO_CACHE_DIR=1
ENV HF_HUB_ENABLE_HF_TRANSFER=0

# Sys deps matching vllm-omni Dockerfile.ci.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        espeak-ng ffmpeg git sox libsox-fmt-all jq curl zstd ca-certificates build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Clone vllm-omni at the pinned tag (SHA recorded above for provenance).
RUN git clone --depth=1 --branch v0.18.0 https://github.com/vllm-project/vllm-omni.git /workspace/vllm-omni && \
    cd /workspace/vllm-omni && \
    git rev-parse HEAD > /workspace/vllm-omni-sha.txt && \
    # Strip fa3-fwd (not available / not needed on SM121 aarch64); FA2 handles attention.
    sed -i '/fa3-fwd/d' requirements/cuda.txt

# Install vllm-omni into the base image's Python env; pulls the rest of the deps.
RUN cd /workspace/vllm-omni && uv pip install --system --no-cache-dir ".[dev]"

# Flash-attention: rely on `vllm-flash-attn` bundled in the vllm-openai base image.
# Only `fa3-fwd` (experimental FA3 forward) is stripped because it isn't required on SM121
# and would force a source compile. If the runtime import fails during the spike we'll
# fall back to `pip install flash-attn --no-build-isolation` at that point.
RUN python3 -c "import vllm_flash_attn; print('vllm_flash_attn OK:', vllm_flash_attn.__version__)" || \
    pip install --no-cache-dir packaging ninja && \
    pip install --no-cache-dir --no-build-isolation flash-attn==2.7.4.post1 || true

# Prefetch the Qwen3-TTS model at the pinned HF revision so production runtime needs no network.
RUN pip install --no-cache-dir 'huggingface_hub[cli]>=0.26' && \
    huggingface-cli download ${HF_MODEL_ID} \
        --revision ${HF_MODEL_REVISION} \
        --local-dir /models/qwen3-tts-1.7b

# Vendor the stage config into the image at a known path (not dependent on vllm-omni layout drift).
RUN mkdir -p /opt/stage_configs && \
    cp /workspace/vllm-omni/vllm_omni/model_executor/stage_configs/qwen3_tts.yaml /opt/stage_configs/qwen3_tts.yaml

# Emit a frozen lockfile + wheelhouse (the Phase 2 production Dockerfile will consume these).
# NOTE: FA2 and vllm-omni are built-from-source; their wheels need to be preserved manually.
RUN pip freeze --all > /workspace/requirements.lock && \
    mkdir -p /workspace/wheelhouse && \
    pip wheel --no-deps --wheel-dir /workspace/wheelhouse /workspace/vllm-omni/ || true

EXPOSE 8092

# Base image already has ENTRYPOINT=[vllm, serve]; CMD provides args only.
CMD ["/models/qwen3-tts-1.7b", \
     "--stage-configs-path", "/opt/stage_configs/qwen3_tts.yaml", \
     "--omni", "--port", "8092", \
     "--trust-remote-code", "--enforce-eager"]
