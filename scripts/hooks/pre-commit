#!/bin/bash
# Pre-commit hook — mirrors CI checks locally.
# Install: git config core.hooksPath scripts/hooks/
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "Running pre-commit checks..."

# 1. Ruff lint
if command -v ruff &>/dev/null; then
    ruff check src/ tests/ --quiet 2>/dev/null || { echo "✗ ruff lint failed"; exit 1; }
    echo "  ✓ ruff lint"
fi

# 2. Secret scan
python3 scripts/check_secrets.py || exit 1

# 3. JS syntax check (no duplicate top-level consts)
python3 -c "
from pathlib import Path
from collections import Counter
js = (Path('static/js/scribe-app.js')).read_text()
lines = js.split('\n')
top = [l.strip().split()[1].rstrip(';=,') for l in lines if not l.startswith((' ','\t')) and (l.strip().startswith('const ') or l.strip().startswith('let '))]
dupes = {k:v for k,v in Counter(top).items() if v>1}
if dupes:
    print(f'  ✗ Duplicate JS declarations: {dupes}')
    exit(1)
print('  ✓ JS syntax')
" || exit 1

echo "All pre-commit checks passed ✓"
