# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
# Anchor to repo root so static/css/dist/ (committed Tailwind build
# output) isn't accidentally ignored. The Python build/dist directory
# only ever appears at the top level.
/dist/

# Environment / secrets
.env
.env.local
.env.*.local
.local/

# TLS certs (local only)
certs/

# Runtime meeting data
meetings/

# Claude Code
.claude/
CLAUDE.md
.claude.json

# Tailwind v4 standalone CLI binary (per-platform; sha256-pinned in
# scripts/tailwind_versions.json; installed by scripts/install_tailwind.py).
# The binary itself never gets committed — only the version manifest does.
.tools/

# build_css.py --mode check builds into here; never committed.
.build-cache/

# Internal-only docs (kept out of public repo)
STRATEGIC_REVIEW.md
COMPETITIVE-LANDSCAPE.md

# macOS
.DS_Store

# Editors
*.swp
*.swo
*~
.idea/
.vscode/

# mise
.mise.local.toml

# Audio files — never commit recordings or samples
*.wav
*.mp3
*.m4a
*.ogg
*.webm
*.flac
*.pcm

# Allowlist: validate-fixture audio is short, sanitized, and required
# by `meeting-scribe validate --full`.
!tests/fixtures/validate/*.wav

# Allowlist: 2.3 KB silent-loop track is the guest page's audio session
# keeper (loaded by static/guest.html so the iOS audio category stays
# "playback" — without it the ringer switch silences interpretation).
# Generated by scripts/generate_silent_loop.py.
!static/silent-loop.mp3

# Allowlist: synthetic-probe fixture is a 1.5s 200 Hz tone used by the
# meeting-start preflight gate (W4). Generated deterministically by
# scripts/gen_probe_audio_fixture.py, so committing the small (~48 KB)
# binary keeps test setup zero-config.
!tests/fixtures/probe_audio_1500ms.wav

# Benchmark audio samples — contain voice recordings, never commit
benchmarks/samples/

# Benchmark results — synthetic test data only, safe to commit
# benchmarks/results/  (allowed)

# Per-machine ad-hoc baselines are scratch data — committed runs use the
# named-experiment pattern (`baseline_<date>_<change>.json`,
# `<model>-<config>_<lang>_to_<lang>.json`, etc). The `_local_` infix
# marks dev-box throwaways from 2026-04-30 OOM debugging — keep them
# out of git so each machine's runs stay local.
benchmarks/results/baseline_local_*.json

# Live-stack regression outputs are produced from private saved meetings.
# They can contain derived transcript snippets, so hook runs write to /tmp
# by default and repo-local copies stay untracked.
benchmarks/results/live_stack_*.json
benchmarks/results/live_context_ab_*.json
benchmarks/results/current_poly_review_*.json

# 2026-Q2 model-challenger bench — only decision_gate.md may land in repo.
# All raw outputs (per-sample JSON, WAVs, MOS forms, RTTM, transcripts)
# live offline at /data/meeting-scribe-fixtures/bench-runs/.  Belt + braces:
# even if a script writes to the wrong place, git will not pick it up.
reports/2026-Q2-bench/**/*.json
reports/2026-Q2-bench/**/*.jsonl
reports/2026-Q2-bench/**/*.csv
reports/2026-Q2-bench/**/*.wav
reports/2026-Q2-bench/**/*.txt
reports/2026-Q2-bench/**/*.rttm

# ML model cache
.cache/

# Coverage artifacts
.coverage
.coverage.*
htmlcov/

# Runtime diagnostics log (rotated by meeting_scribe.diagnostics)
diagnostics/server.log
diagnostics/server.log.*
# Per-run validate reports (keep schema in code, not on disk)
diagnostics/validate-*.json
# scripts/check_backend_apis.py append-only probe log
docs/backend_api_log.jsonl
# Per-run diagnostic captures (DOM snapshots, screenshots, console
# logs) from scripts/diag_slide_viewer.py and friends. Each run
# overwrites them; useful at triage time but not in version control.
tests/fixtures/diag/

# Generated on the fly by the security CI lane and scripts/ci_local.py
# (npm install --package-lock-only). Not committed because the overlay
# tree is tiny — Electron + a few transitives — and the lockfile would
# bloat reviews.
overlay/package-lock.json
.ai-hooks/
# Playwright visual-regression diff outputs — only the masked .png baselines are tracked; .actual.png is regenerated on every test run.
tests/browser/__snapshots__/**/*.actual.png
# Ad-hoc render-check screenshots produced by scripts/playwright_render_check.py.
# Regenerable any time the sidecar is running; not authoritative baselines.
tests/browser/__snapshots__/migration_render/
# Phase S settings-panel visual captures produced by
# scripts/_capture_settings_screenshots.py — also regenerable, not authoritative.
tests/browser/__snapshots__/phase_s_settings/
tests/browser/__snapshots__/_ux_audit/
