# meeting-scribe GB10 environment template
#
# Copy to .env and fill in GB10_HOST:
#   cp .env.gb10 .env
#   $EDITOR .env
#
# Or source directly:
#   set -a && source .env.gb10 && set +a && meeting-scribe start --foreground

# Profile — sets all backends to GB10 production mode
SCRIBE_PROFILE=gb10

# GB10 node IP (for remote management via CLI)
SCRIBE_GB10_HOST=

# Network — bind to all interfaces (accessible from other machines)
SCRIBE_HOST=0.0.0.0
SCRIBE_PORT=8080

# ASR — Qwen3-ASR via vLLM (1.5s buffer, real-time transcription)
SCRIBE_ASR_MODEL=Qwen/Qwen3-ASR-1.7B

# Translation — shared vLLM model with autosre coding agent (port 8010)
SCRIBE_TRANSLATE_BACKEND=vllm
SCRIBE_TRANSLATE_VLLM_URL=http://localhost:8010

# Diarization — pyannote.audio speaker diarization
SCRIBE_DIARIZE=true
SCRIBE_DIARIZE_URL=http://localhost:8001

# TTS — Qwen3-TTS via faster-qwen3-tts (interpretation audio synthesis)
SCRIBE_TTS_VLLM_URL=http://localhost:8002

# Speaker name extraction — LLM via translation endpoint
SCRIBE_NAME_EXTRACTION=auto

# Docker image for vLLM containers
SCRIBE_VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:turboquant

# HuggingFace cache on GB10
HF_CACHE_DIR=/data/huggingface
