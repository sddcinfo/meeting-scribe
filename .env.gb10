# meeting-scribe GB10 environment template
#
# Copy to .env and fill in GB10_HOST:
#   cp .env.gb10 .env
#   $EDITOR .env
#
# Or source directly:
#   set -a && source .env.gb10 && set +a && meeting-scribe start --foreground

# Profile — sets all backends to GB10 production mode
SCRIBE_PROFILE=gb10

# GB10 node IP (for remote management via CLI)
SCRIBE_GB10_HOST=

# Network — bind to all interfaces (accessible from other machines)
SCRIBE_HOST=0.0.0.0
SCRIBE_PORT=8080

# ASR — Qwen3-ASR via vLLM (1.5s buffer, real-time transcription)
SCRIBE_ASR_MODEL=Qwen/Qwen3-ASR-1.7B

# Translation — shared vLLM model with autosre coding agent (port 8010)
SCRIBE_TRANSLATE_BACKEND=vllm
SCRIBE_TRANSLATE_VLLM_URL=http://localhost:8010

# Diarization — pyannote.audio speaker diarization
SCRIBE_DIARIZE=true
SCRIBE_DIARIZE_URL=http://localhost:8001

# TTS — Qwen3-TTS interpretation audio synthesis.
# GB10 reliability mode: faster-qwen3-tts 0.2.6 on the pinned PyTorch 2.11
# image passed the 2026-05-09 saved-meeting live-stack regression. Keep
# x-vector cloning and upstream-style text feeding for interpretation TTS.
# The audio-budget trio mirrors the benchmark gate: hard cap plus dynamic
# phrase-length cap (base + per-char). If Qwen runs away, emit only bounded
# audio and keep the worker alive; only real synthesis failures/timeouts
# restart the container.
# Two concurrent TTS containers pushed GPU memory high enough to CUDA-OOM.
TTS_BACKEND=faster
TTS_FASTER_XVEC_ONLY=1
TTS_FASTER_NON_STREAMING_MODE=0
TTS_SERVER_SYNTH_TIMEOUT_S=45
TTS_MAX_AUDIO_S=12
TTS_MAX_AUDIO_BASE_S=1.5
TTS_MAX_AUDIO_PER_CHAR_S=0.22
SCRIBE_TTS_VLLM_URL=http://localhost:8002
SCRIBE_TTS_CONTAINER_CONCURRENCY=1
SCRIBE_TTS_QUEUE_MAXSIZE=32
SCRIBE_TTS_WORKER_COUNT=2
# Room/headset playback must queue enough completed TTS segments to absorb
# slow PipeWire/USB/BT writes. A tiny queue makes TTS look stalled because
# generated audio is dropped before it reaches the operator headset.
SCRIBE_LOCAL_SINK_QUEUE_MAXSIZE=64
SCRIBE_LOCAL_SINK_WRITE_TIMEOUT_S=2.5
SCRIBE_TTS_MAX_SPEECH_LAG_S=20
SCRIBE_TTS_SYNTH_TIMEOUT_BASE_S=45
SCRIBE_TRANSLATE_QUEUE_MAXSIZE=50
SCRIBE_TRANSLATE_TIMEOUT_SECONDS=30
SCRIBE_LIVE_TRANSLATE_CONTEXT_DIRECTIONS=ja:en
SCRIBE_SPEECH_ACTIVITY_RMS_THRESHOLD=0.0035
SCRIBE_LIVE_DIARIZE_QUEUE_MAX=256
SCRIBE_AUDIO_OUT_MAX_CLIENTS=32
SCRIBE_AUDIO_FORMAT_GRACE_S=1.0
SCRIBE_AUDIO_FORMAT_PENDING_CAP_S=1.0

# Speaker name extraction — LLM via translation endpoint
SCRIBE_NAME_EXTRACTION=auto

# Docker image for the ASR vLLM container. Override only if you need a
# custom build. The default points at scribe-vllm-asr:latest, a thin
# layer over vllm/vllm-openai:latest that adds the vllm[audio] extras
# (soundfile, av, soxr) Qwen3-ASR needs.  Build it with:
#   docker build -t scribe-vllm-asr:latest containers/vllm-asr/
SCRIBE_VLLM_IMAGE=scribe-vllm-asr:latest

# HuggingFace cache on GB10
HF_CACHE_DIR=/data/huggingface
